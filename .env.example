# ── Clerk Auth ───────────────────────────────────────
# Dapatkan dari: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_publishable_key_here
CLERK_SECRET_KEY=your_secret_key_here
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/masuk
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/daftar
# CATATAN: Dua env var di bawah DEPRECATED di Clerk v6
# Redirect sudah dikonfigurasi langsung di ClerkProvider (app/layout.tsx)
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── Cloudflare Workers API ──────────────────────────
# URL Workers setelah deploy: https://holanu-api.YOUR_SUBDOMAIN.workers.dev
# Di local dev: kosongkan agar request di-proxy via Next.js (lihat next.config.mjs)
NEXT_PUBLIC_API_URL=https://holanu-api.YOUR_SUBDOMAIN.workers.dev

# ── ImageKit.io ──────────────────────────────────────
# Dapatkan dari: https://imagekit.io/dashboard/developer/api-keys
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/YOUR_IMAGEKIT_ID
NEXT_PUBLIC_IMAGEKIT_PUBLIC_KEY=public_XXXXXXXXXXXXXXXXXXXXXXXX
# IMAGEKIT_PRIVATE_KEY disimpan sebagai Cloudflare Workers Secret, bukan .env Next.js
# Jalankan: wrangler secret put IMAGEKIT_PRIVATE_KEY

# ── WhatsApp Support ─────────────────────────────────
# Nomor WA bisnis untuk tombol support, bantuan, dan konsultasi
# Format: 62 + nomor tanpa 0 di depan (contoh: 628112345678)
NEXT_PUBLIC_SUPPORT_WA=628XXXXXXXXXXX

# ── Groq AI (Chatbot) ────────────────────────────────
# Dapatkan API key gratis di: https://console.groq.com
# Digunakan untuk chatbot AI di homepage (llama-3.1-8b-instant)
# Gratis: 14.400 request/hari
GROQ_API_KEY=gsk_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── App Config ───────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://holanu.id
NEXT_PUBLIC_SITE_NAME=HOLANU
